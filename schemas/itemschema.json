{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sechael.github.io/pta-data/schemas/itemschema.json",
    "title": "PTA Item (future mechanics shape)",
    "type": "object",
    "additionalProperties": false,
    "$comment": "This schema documents the forward-looking item payload + mechanics model. Current lib/items.json is legacy (effect_type/effect_value/is_percentage) and is intentionally not validated by this schema yet.",
    "required": [
        "type",
        "id",
        "name",
        "description",
        "category",
        "rarity",
        "price",
        "is_consumable",
        "size",
        "sprite"
    ],
    "properties": {
        "type": {
            "type": "string",
            "const": "item",
            "description": "Catalog row discriminator. All entries under lib/items/*.json use \"item\"."
        },
        "id": {
            "type": "string",
            "minLength": 1,
            "description": "Stable item id / slug (e.g. wepear-berry)."
        },
        "name": {
            "type": "string",
            "minLength": 1
        },
        "description": {
            "type": "string"
        },
        "category": {
            "type": "string",
            "enum": [
                "Berry",
                "Evolution",
                "Held Item",
                "Key Item",
                "Medical",
                "Pokeball",
                "Supplies",
                "TM",
                "Trainer Equipment"
            ],
            "description": "High-level item category. Derived from lib/items.json categories."
        },
        "rarity": {
            "type": "string",
            "enum": [
                "Common",
                "Uncommon",
                "Rare",
                "Unique",
                "Craftable"
            ]
        },
        "price": {
            "type": "integer",
            "minimum": 0
        },
        "is_consumable": {
            "type": "boolean"
        },
        "size": {
            "type": "string",
            "enum": [
                "1x1",
                "2x2",
                "2x4",
                "3x2",
                "4x2"
            ]
        },
        "sprite": {
            "type": "string",
            "description": "Relative asset path (e.g. items/wepear-berry.png)."
        },
        "sprite_url": {
            "type": "string",
            "description": "Optional remote sprite URL.",
            "format": "uri"
        },
        "equipslot": {
            "description": "Optional equip slot for wearable/held items (or null for not equippable).",
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "string",
                    "enum": [
                        "armor",
                        "gear",
                        "onehand",
                        "twohand"
                    ]
                }
            ]
        },
        "flavors": {
            "description": "Contest flavors for berries and similar. Canonical shape is an array; legacy data may store a JSON-encoded string.",
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "Sweet",
                    "Sour",
                    "Bitter",
                    "Spicy",
                    "Dry"
                ]
            }
        },
        "conditions": {
            "description": "Optional additive restrictions for when/whom the item can be used on (e.g. HUMAN vs POKEMON, CONSCIOUS vs FAINTED).",
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true,
            "examples": [
                [
                    "POKEMON",
                    "CONSCIOUS"
                ],
                [
                    "POKEMON",
                    "FAINTED"
                ],
                [
                    "HUMAN",
                    "CONSCIOUS"
                ]
            ]
        },
        "mechanics": {
            "description": "List of mechanics applied when using, holding, or otherwise benefiting from the item.",
            "type": "array",
            "items": {
                "$ref": "#/$defs/Mechanic"
            }
        },
        "container": {
            "description": "Optional container metadata for items that can hold other items (e.g. pokeball-container, trainer-ration-container, pokemon-food-bag). This is staging-only; current lib/items.json encodes this in description text.",
            "$ref": "#/$defs/Container"
        }
    },
    "$defs": {
        "Container": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "capacity",
                "unit",
                "allowed"
            ],
            "properties": {
                "capacity": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Maximum amount that can be stored (counted in `unit`)."
                },
                "unit": {
                    "type": "string",
                    "enum": [
                        "ITEM",
                        "PORTION",
                        "BALL",
                        "RATION_UNIT"
                    ],
                    "description": "Unit of measurement for `capacity` (discrete items vs tracked portions/units)."
                },
                "allowed": {
                    "description": "What the container is allowed to hold.",
                    "oneOf": [
                        {
                            "$ref": "#/$defs/ContainerAllowedByCategory"
                        },
                        {
                            "$ref": "#/$defs/ContainerAllowedByItemId"
                        },
                        {
                            "$ref": "#/$defs/ContainerAllowedByCategoryOrItemId"
                        }
                    ]
                }
            },
            "examples": [
                {
                    "capacity": 12,
                    "unit": "BALL",
                    "allowed": {
                        "categories": [
                            "Pokeball"
                        ]
                    }
                },
                {
                    "capacity": 12,
                    "unit": "RATION_UNIT",
                    "allowed": {
                        "itemIds": [
                            "trainer-ration-24-hour"
                        ]
                    }
                },
                {
                    "capacity": 50,
                    "unit": "PORTION",
                    "allowed": {
                        "itemIds": [
                            "pokemon-food"
                        ]
                    }
                }
            ]
        },
        "ContainerAllowedByCategory": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "categories"
            ],
            "properties": {
                "categories": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "enum": [
                            "Berry",
                            "Evolution",
                            "Held Item",
                            "Key Item",
                            "Medical",
                            "Pokeball",
                            "Supplies",
                            "TM",
                            "Trainer Equipment"
                        ]
                    },
                    "uniqueItems": true
                }
            }
        },
        "ContainerAllowedByItemId": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "itemIds"
            ],
            "properties": {
                "itemIds": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "uniqueItems": true,
                    "description": "Explicit allow-list of item ids this container can hold."
                }
            }
        },
        "ContainerAllowedByCategoryOrItemId": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "categories",
                "itemIds"
            ],
            "properties": {
                "categories": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "enum": [
                            "Berry",
                            "Evolution",
                            "Held Item",
                            "Key Item",
                            "Medical",
                            "Pokeball",
                            "Supplies",
                            "TM",
                            "Trainer Equipment"
                        ]
                    },
                    "uniqueItems": true
                },
                "itemIds": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "uniqueItems": true
                }
            }
        },
        "Mechanic": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "type",
                "target",
                "value",
                "resource"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "description": "The kind of operation (the \"what\"). Examples: HEAL, DAMAGE, STAT_MOD, CONDITION."
                },
                "target": {
                    "type": "string",
                    "enum": [
                        "SELF",
                        "SELECTED",
                        "FOE",
                        "AOE"
                    ],
                    "description": "Who is affected by the mechanic."
                },
                "value": {
                    "description": "The raw magnitude or a formula.",
                    "anyOf": [
                        {
                            "type": "number"
                        },
                        {
                            "type": "string",
                            "minLength": 1
                        }
                    ]
                },
                "resource": {
                    "type": "string",
                    "description": "What is being changed (HP, PP, CAPTURE, condition name, etc.).",
                    "minLength": 1
                },
                "params": {
                    "type": "object",
                    "description": "Optional structured parameters for mechanics that need extra configuration (e.g. item initialization choices, persistence keys).",
                    "additionalProperties": true
                }
            },
            "examples": [
                {
                    "type": "HEAL",
                    "target": "SELECTED",
                    "value": 50,
                    "resource": "HP"
                }
            ]
        }
    }
}
