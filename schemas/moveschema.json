{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sechael.github.io/pta-data/schemas/moveschema.json",
    "title": "PTA move catalog (array)",
    "type": "array",
    "items": {
        "$ref": "#/$defs/Move"
    },
    "$defs": {
        "Move": {
            "type": "object",
            "additionalProperties": true,
            "$comment": "Canonical key order: type, id, name, move_type, category, description, then optional proficency, contest, mechanics (frequency … ranges, optional damage_bonus, move_keyword, effects).",
            "required": [
                "type",
                "id",
                "name",
                "move_type",
                "category",
                "description",
                "mechanics"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "const": "move",
                    "description": "Catalog row discriminator."
                },
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "move_type": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Pokémon move type (e.g. Normal, Grass)."
                },
                "category": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Move category (e.g. Attack, Special, Effect)."
                },
                "description": {
                    "type": "string"
                },
                "proficency": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": "Optional typing/proficiency tags (legacy spelling)."
                },
                "contest": {
                    "description": "Contest presentation; null when not applicable.",
                    "anyOf": [
                        {
                            "type": "null"
                        },
                        {
                            "type": "object",
                            "additionalProperties": false,
                            "required": [
                                "stat",
                                "keyword"
                            ],
                            "properties": {
                                "stat": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "keyword": {
                                    "type": "string",
                                    "minLength": 1
                                }
                            }
                        }
                    ]
                },
                "mechanics": {
                    "$ref": "#/$defs/MoveMechanics"
                }
            }
        },
        "MoveMechanics": {
            "type": "object",
            "additionalProperties": false,
            "description": "Combat frame for the move (frequency, accuracy, range) plus effect lines.",
            "required": [
                "frequency",
                "accuracy",
                "attack_type",
                "target",
                "target_range",
                "effect_radius",
                "move_keyword",
                "effects"
            ],
            "properties": {
                "frequency": {
                    "$ref": "#/$defs/MoveFrequency"
                },
                "accuracy": {
                    "type": "number",
                    "description": "Accuracy modifier for the attack roll (formerly accuracy_mod)."
                },
                "attack_type": {
                    "type": "string",
                    "description": "How the move is delivered (e.g. melee, ranged)."
                },
                "target": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Attack targeting pattern (e.g. Single, burst, blast)."
                },
                "target_range": {
                    "type": "number",
                    "description": "Primary range to valid targets (formerly range_value_1)."
                },
                "effect_radius": {
                    "type": "number",
                    "description": "Secondary radius for area patterns (formerly range_value_2)."
                },
                "damage_bonus": {
                    "type": "number",
                    "description": "Optional flat add to damage. When absent or zero, dice damage.value must not use a +X suffix; +X is only meaningful when this is non-zero."
                },
                "move_keyword": {
                    "$ref": "#/$defs/MoveKeyword",
                    "description": "Single tactical tag distilled from rules text (before effect lines)."
                },
                "effects": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/MoveMechanic"
                    }
                }
            }
        },
        "MoveKeyword": {
            "description": "Normalized keyword from PTA move rules (Binding, Coat, Hazard, etc.). Null when none apply.",
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "string",
                    "enum": [
                        "Binding",
                        "Coat",
                        "Hazard",
                        "Multi-turn",
                        "Priority",
                        "Reaction",
                        "Scatter",
                        "Terrain",
                        "Weather"
                    ]
                }
            ]
        },
        "MoveFrequency": {
            "description": "Uses per day, at-will, varies, or unknown (null).",
            "oneOf": [
                {
                    "type": "integer",
                    "enum": [
                        1,
                        3
                    ]
                },
                {
                    "type": "string",
                    "enum": [
                        "At-Will",
                        "Varies"
                    ]
                },
                {
                    "type": "null"
                }
            ]
        },
        "MechanicDamage": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "kind",
                "value"
            ],
            "$comment": "Suffix +X in value is reserved for flat bonus from mechanics.damage_bonus (non-zero). Do not encode +X when damage_bonus is absent or 0.",
            "properties": {
                "kind": {
                    "type": "string",
                    "enum": [
                        "Flat",
                        "Dice",
                        "None"
                    ],
                    "description": "Flat = fixed HP; Dice = rolled expression; None = no damage component."
                },
                "value": {
                    "type": "string",
                    "description": "Damage when kind is Flat or Dice (e.g. \"25\", \"2d6\", \"1d12+3\"). Use \"...+X\" only when mechanics.damage_bonus is non-zero. Empty when kind is None."
                }
            }
        },
        "MoveMechanic": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "type",
                "target",
                "value",
                "resource",
                "damage"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "description": "The kind of operation: DAMAGE, HEAL, STAT_MOD, CONDITION, etc."
                },
                "target": {
                    "type": "string",
                    "enum": [
                        "SELF",
                        "SELECTED",
                        "FOE",
                        "AOE"
                    ],
                    "description": "Who is affected by this effect."
                },
                "value": {
                    "description": "Magnitude, tag, or formula depending on type.",
                    "anyOf": [
                        {
                            "type": "number"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "resource": {
                    "type": "string",
                    "minLength": 1,
                    "description": "What is being changed (HP, SPDEF, STUN, etc.)."
                },
                "damage": {
                    "$ref": "#/$defs/MechanicDamage"
                },
                "params": {
                    "type": "object",
                    "description": "Optional structured parameters.",
                    "additionalProperties": true
                }
            },
            "examples": [
                {
                    "type": "DAMAGE",
                    "target": "FOE",
                    "value": "2d6",
                    "resource": "HP",
                    "damage": {
                        "kind": "Dice",
                        "value": "2d6"
                    }
                }
            ]
        }
    }
}
