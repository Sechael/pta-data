  "description": "PTA catalog JSON datasets (Pokémon, moves, items, weapons, afflictions, type chart, mega/gmax variants, trainer pools).",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sechael/pta-data.git"
  },
  "type": "module",
  "files": ["lib", "README.md"],
  "scripts": {
    "validate": "node scripts/validate.mjs"
  },
