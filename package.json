    "./lib/moves.json": "./lib/moves.json",
    "./lib/pokemon.json": "./lib/pokemon.json",
    "./lib/pokemon-gmax.json": "./lib/pokemon-gmax.json",
    "./lib/pokemon-mega.json": "./lib/pokemon-mega.json",
    "./lib/trainer-class-move-pools.json": "./lib/trainer-class-move-pools.json",
    "./lib/type-chart.json": "./lib/type-chart.json",
    "./lib/weapons.json": "./lib/weapons.json"
  }
